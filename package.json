    "pwa",
    "leaflet",
    "openstreetmap",
    "santa-rita-do-pardo",
    "transporte",
    "tempo-real",
    "lgpd",
    "capacitor",
    "android",
    "mobile",
    "app"
  ],
  "author": "VDB / Bianca",
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^7.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@capacitor/android": "^7.4.3"
  }
}
