# Copie este arquivo para android/keystore.properties e preencha com seus dados reais.
# NUNCA versionar o arquivo android/keystore.properties com segredos.

# Caminho para seu keystore (.jks)
storeFile=C:/caminho/para/seu-keystore.jks

# Senha do keystore
storePassword=troque_essa_senha

# Alias da chave de assinatura
keyAlias=seu_alias

# Senha da chave
keyPassword=troque_essa_senha
