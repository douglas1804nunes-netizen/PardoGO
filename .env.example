# PardoGo - configuração de produção
NODE_ENV=production
PORT=5173
APP_BASE_URL=https://seudominio.com.br

# Banco SQLite persistente
DB_PATH=./data/pardogo.sqlite

# Admin inicial. Troque antes de subir online.
ADMIN_INITIAL_PHONE=admin
ADMIN_INITIAL_PASSWORD=troque-essa-senha-forte

# Sessões
SESSION_DAYS=7

# Segurança HTTP
# Use FORCE_HTTPS=1 quando estiver atrás de proxy/host com HTTPS ativo.
FORCE_HTTPS=1
TRUST_PROXY=1
REQUIRE_SECURE_ENV=0
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# Mapa/rota
CITY_AVERAGE_SPEED_KMH=28
MAP_TIMEOUT_MS=5500
SSE_PING_MS=25000

# Etapa 14 - app mobile
# Use * durante testes ou informe o domínio do app/Capacitor quando controlar a origem.
CORS_ORIGIN=*
# URL pública do backend usada na documentação do app. A URL efetiva do app fica em public/mobile-config.js.
PUBLIC_APP_API_URL=https://api.seudominio.com

# Google Sign-In (opcional)
# Use o mesmo client ID no servidor (abaixo) e em public/mobile-config.js (googleClientId).
GOOGLE_CLIENT_ID=
